{
  "title": "MFE Errors",
  "uid": "mfe-errors",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["mfe", "errors"],
  "panels": [
    {
      "id": 1,
      "title": "Error Logs per MFE",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (rate({job=\"docker\", level=\"error\"}[2m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "id": 2,
      "title": "mfe-auth Errors",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\", service=\"mfe-auth\", level=\"error\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 3,
      "title": "BFF Errors",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\", level=\"error\"} |= \"bff\" | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 4,
      "title": "Top 10 Most Frequent Errors",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (msg) (count_over_time({job=\"docker\", level=\"error\"} | json | __error__=\"\" [1h])))",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": { "fields": [{ "desc": true, "displayName": "Value" }] }
        }
      ]
    }
  ]
}

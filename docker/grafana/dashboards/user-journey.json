{
  "title": "User Journey",
  "uid": "user-journey",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["mfe", "sessions"],
  "panels": [
    {
      "id": 1,
      "title": "Auth Events (login / register)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (url) (rate({job=\"docker\"} |= \"/api/auth\" | json [5m]))",
          "legendFormat": "{{url}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Dashboard Visits",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\"} |= \"/api/dashboard\" | json [5m]))",
          "legendFormat": "dashboard requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Products MFE Activity",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\"} |= \"/api/products\" | json [5m]))",
          "legendFormat": "products requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Login Success vs Failure",
      "type": "piechart",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\"} |= \"/api/auth/login\" |= \"200\" | json [1h]))",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"docker\"} |= \"/api/auth/login\" | json | statusCode >= 400 [1h]))",
          "legendFormat": "failure",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Trace log — by traceId",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\"} | json | traceId != \"\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      }
    }
  ]
}
